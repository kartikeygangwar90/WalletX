<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transfer</title>
</head>
<body>
    <h3>You can transfer the choosen amount !! </h3>
    <h5>The maximum you have is : <%= userData?.balance %></h5>
    <form action="/wallet/transfer" method="POST">
        <label>Send to: </label>
        <select name="receiverId" required>
            <% users.forEach(user => { %>
                <option value="<%= user._id %>">
                    <%= user.name %>
                </option>
            <% }) %>
        </select>

        <br> <br>
        
        <input 
        type="number" 
        name="amount" 
        placeholder="Enter Amount"
        min = "1"
        required
        />
        <button type="submit">Send</button>
    </form>
</body>
</html>