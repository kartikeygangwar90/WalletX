<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WalletX</title>
</head>
<body>
    <h1>Welcome! <%= userData ? userData.name : "User" %> to Digi Mess</h1>
    <% if(userData) { %>
        <form action="/wallet/<%= userData._id %>/balance" method="get">
            <button type="submit">Check Your Balance</button>
        </form>
        <form action="/wallet/<%= userData._id %>/transfer" method="get">
            <button type="submit">Transfer Amount</button>
        </form>
        <form action="/wallet/<%= userData._id %>/addCredit" method="get">
            <button type="submit">Add-Credit</button>
        </form>
        <form action="/wallet/<%= userData._id %>/transaction" method="get">
            <button type="submit">Pay Now</button>
        </form>
    <% } else { %>
        <h4>User not found</h4>
    <% } %>
</body>
</html>